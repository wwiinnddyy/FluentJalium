<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:animation="clr-namespace:Jalium.UI.Media.Animation;assembly=Jalium.UI.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <animation:Duration x:Key="FluentMotionDurationFast">0:0:0.12</animation:Duration>
    <animation:Duration x:Key="FluentMotionDurationNormal">0:0:0.28</animation:Duration>
    <animation:Duration x:Key="FluentMotionDurationEmphasized">0:0:0.32</animation:Duration>
    <animation:Duration x:Key="FluentMotionConnectedAnimationDuration">0:0:0.32</animation:Duration>
    <x:String x:Key="FluentMotionConnectedAnimationInitialOpacity">0.72</x:String>
    <animation:Duration x:Key="FluentMotionConnectedAnimationNavigationDuration">0:0:0.32</animation:Duration>
    <x:String x:Key="FluentMotionConnectedAnimationNavigationInitialOpacity">0.72</x:String>
    <animation:Duration x:Key="FluentMotionConnectedAnimationEntranceDuration">0:0:0.24</animation:Duration>
    <x:String x:Key="FluentMotionConnectedAnimationEntranceInitialOpacity">0.0</x:String>
    <animation:Duration x:Key="FluentMotionConnectedAnimationDirectDuration">0:0:0.32</animation:Duration>
    <x:String x:Key="FluentMotionConnectedAnimationDirectInitialOpacity">0.72</x:String>
    <animation:Duration x:Key="FluentMotionConnectedAnimationGravityDuration">0:0:0.36</animation:Duration>
    <x:String x:Key="FluentMotionConnectedAnimationGravityInitialOpacity">0.64</x:String>

    <x:String x:Key="FluentMotionContentTransitionDefaultMode">Crossfade</x:String>
    <animation:Duration x:Key="FluentMotionContentTransitionDefaultDuration">0:0:0.28</animation:Duration>
    <x:String x:Key="FluentMotionContentTransitionDefaultTimingFunction">Recommended</x:String>
    <x:String x:Key="FluentMotionContentTransitionEntranceMode">SlideLeft</x:String>
    <animation:Duration x:Key="FluentMotionContentTransitionEntranceDuration">0:0:0.32</animation:Duration>
    <x:String x:Key="FluentMotionContentTransitionEntranceTimingFunction">EaseOut</x:String>
    <x:String x:Key="FluentMotionContentTransitionDrillInMode">ZoomIn</x:String>
    <animation:Duration x:Key="FluentMotionContentTransitionDrillInDuration">0:0:0.36</animation:Duration>
    <x:String x:Key="FluentMotionContentTransitionDrillInTimingFunction">EaseInOut</x:String>
    <x:String x:Key="FluentMotionContentTransitionBackNavigationMode">SlideRight</x:String>
    <animation:Duration x:Key="FluentMotionContentTransitionBackNavigationDuration">0:0:0.28</animation:Duration>
    <x:String x:Key="FluentMotionContentTransitionBackNavigationTimingFunction">EaseOut</x:String>
    <x:String x:Key="FluentMotionContentTransitionLiquidMorphMode">LiquidMorph</x:String>
    <animation:Duration x:Key="FluentMotionContentTransitionLiquidMorphDuration">0:0:0.42</animation:Duration>
    <x:String x:Key="FluentMotionContentTransitionLiquidMorphTimingFunction">EaseInOut</x:String>
    <x:String x:Key="FluentMotionContentTransitionSuppressMode">None</x:String>
    <animation:Duration x:Key="FluentMotionContentTransitionSuppressDuration">0:0:0</animation:Duration>
    <x:String x:Key="FluentMotionContentTransitionSuppressTimingFunction">Linear</x:String>
</ResourceDictionary>
