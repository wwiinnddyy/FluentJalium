    <Style x:Key="FluentChartLegendStyle" TargetType="ChartLegend">
        <Setter Property="Background" Value="{ThemeResource ChartLegendBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource ChartForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ChartLegendBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="{ThemeResource FluentCaptionFontSize}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="ChartLegend">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
