        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="MinHeight" Value="160" />
        <Setter Property="TitleForeground" Value="{ThemeResource ChartTitleForeground}" />
        <Setter Property="AxisBrush" Value="{ThemeResource ChartAxisBrush}" />
        <Setter Property="GridLineBrush" Value="{ThemeResource ChartGridLineBrush}" />
        <Setter Property="BarCornerRadius" Value="3,3,0,0" />
        <Setter Property="Template">
            <ControlTemplate TargetType="BarChart">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        ClipToBounds="True" />
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.56" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="fluent:FWBarChart" BasedOn="{StaticResource {x:Type BarChart}}" />

