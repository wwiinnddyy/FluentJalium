<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:fluent="https://jalium.dev/fluent"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="LineChart">
        <Setter Property="Background" Value="{ThemeResource ChartBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource ChartForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ChartBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="MinHeight" Value="160" />
        <Setter Property="TitleForeground" Value="{ThemeResource ChartTitleForeground}" />
        <Setter Property="AxisBrush" Value="{ThemeResource ChartAxisBrush}" />
        <Setter Property="GridLineBrush" Value="{ThemeResource ChartGridLineBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="LineChart">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        ClipToBounds="True" />
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.56" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="fluent:FWLineChart" BasedOn="{StaticResource {x:Type LineChart}}" />

    <Style TargetType="BarChart">
        <Setter Property="Background" Value="{ThemeResource ChartBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource ChartForeground}" />
