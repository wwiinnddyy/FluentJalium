        <Setter Property="Foreground" Value="{ThemeResource ChartTooltipForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ChartTooltipBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,4,8,4" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="{ThemeResource FluentCaptionFontSize}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="ChartTooltip">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style TargetType="fluent:FWChartTooltip" BasedOn="{StaticResource {x:Type ChartTooltip}}" />
