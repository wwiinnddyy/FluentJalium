<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:charts="clr-namespace:Jalium.UI.Controls.Charts;assembly=Jalium.UI.Controls"
    xmlns:fluent="https://jalium.dev/fluent"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="FluentLineChartStyle" TargetType="LineChart">
        <Setter Property="Background" Value="{ThemeResource ChartBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource ChartForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ChartBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="MinHeight" Value="160" />
        <Setter Property="TitleForeground" Value="{ThemeResource ChartTitleForeground}" />
        <Setter Property="AxisBrush" Value="{ThemeResource ChartAxisBrush}" />
        <Setter Property="GridLineBrush" Value="{ThemeResource ChartGridLineBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="LineChart">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        ClipToBounds="True" />
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.56" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="LineChart" BasedOn="{StaticResource FluentLineChartStyle}" />
    <Style TargetType="fluent:FWLineChart" BasedOn="{StaticResource FluentLineChartStyle}" />

    <Style x:Key="FluentBarChartStyle" TargetType="BarChart">
        <Setter Property="Background" Value="{ThemeResource ChartBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource ChartForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ChartBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="MinHeight" Value="160" />
        <Setter Property="TitleForeground" Value="{ThemeResource ChartTitleForeground}" />
        <Setter Property="AxisBrush" Value="{ThemeResource ChartAxisBrush}" />
        <Setter Property="GridLineBrush" Value="{ThemeResource ChartGridLineBrush}" />
        <Setter Property="BarCornerRadius" Value="3,3,0,0" />
        <Setter Property="Template">
            <ControlTemplate TargetType="BarChart">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        ClipToBounds="True" />
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.56" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="BarChart" BasedOn="{StaticResource FluentBarChartStyle}" />
    <Style TargetType="fluent:FWBarChart" BasedOn="{StaticResource FluentBarChartStyle}" />

