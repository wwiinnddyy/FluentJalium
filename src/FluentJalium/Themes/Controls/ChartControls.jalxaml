    <Style x:Key="FluentSparklineStyle" TargetType="Sparkline">
        <Setter Property="Background" Value="{ThemeResource ChartInlineBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource ChartForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ChartInlineBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="MinWidth" Value="64" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="LineBrush" Value="{ThemeResource ChartPalette1}" />
        <Setter Property="FillBrush" Value="{ThemeResource ChartAreaFillBrush}" />
        <Setter Property="HighPointBrush" Value="{ThemeResource ChartPositiveBrush}" />
        <Setter Property="LowPointBrush" Value="{ThemeResource ChartNegativeBrush}" />
        <Setter Property="NegativeBarBrush" Value="{ThemeResource ChartNegativeBrush}" />
        <Setter Property="WinColor" Value="{ThemeResource ChartPositiveBrush}" />
        <Setter Property="LossColor" Value="{ThemeResource ChartNegativeBrush}" />
