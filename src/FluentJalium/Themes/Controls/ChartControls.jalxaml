        <Setter Property="MinHeight" Value="24" />
        <Setter Property="LineBrush" Value="{ThemeResource ChartPalette1}" />
        <Setter Property="FillBrush" Value="{ThemeResource ChartAreaFillBrush}" />
        <Setter Property="HighPointBrush" Value="{ThemeResource ChartPositiveBrush}" />
        <Setter Property="LowPointBrush" Value="{ThemeResource ChartNegativeBrush}" />
        <Setter Property="NegativeBarBrush" Value="{ThemeResource ChartNegativeBrush}" />
