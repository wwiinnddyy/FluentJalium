        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="16" />
        <Setter Property="MinHeight" Value="16" />
    </Style>

    <Style x:Key="CriticalDotInfoBadgeStyle" TargetType="fluent:FWInfoBadge">
        <Setter Property="Severity" Value="Critical" />
        <Setter Property="Background" Value="{ThemeResource InfoBadgeCriticalBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource InfoBadgeCriticalForeground}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="6" />
        <Setter Property="MinHeight" Value="6" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="CriticalValueInfoBadgeStyle" TargetType="fluent:FWInfoBadge">
        <Setter Property="Severity" Value="Critical" />
        <Setter Property="Background" Value="{ThemeResource InfoBadgeCriticalBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource InfoBadgeCriticalForeground}" />
        <Setter Property="Padding" Value="4,0,4,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="16" />
        <Setter Property="MinHeight" Value="16" />
    </Style>

    <Style x:Key="CriticalIconInfoBadgeStyle" TargetType="fluent:FWInfoBadge">
        <Setter Property="Severity" Value="Critical" />
        <Setter Property="Background" Value="{ThemeResource InfoBadgeCriticalBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource InfoBadgeCriticalForeground}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="16" />
        <Setter Property="MinHeight" Value="16" />
    </Style>

    <Style TargetType="DiffViewer">
        <Setter Property="Background" Value="{ThemeResource DataInspectorBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource DataInspectorForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource DataInspectorBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontFamily" Value="{ThemeResource MonoFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="MinHeight" Value="140" />
        <Setter Property="GutterBackground" Value="{ThemeResource DataInspectorGutterBackground}" />
        <Setter Property="LineNumberForeground" Value="{ThemeResource DataInspectorLineNumberForeground}" />
        <Setter Property="SelectionBrush" Value="{ThemeResource DataInspectorSelectionBackground}" />
        <Setter Property="CaretBrush" Value="{ThemeResource DataInspectorForeground}" />
        <Setter Property="AddedLineBrush" Value="{ThemeResource DataInspectorAddedLineBackground}" />
        <Setter Property="RemovedLineBrush" Value="{ThemeResource DataInspectorRemovedLineBackground}" />
        <Setter Property="ModifiedLineBrush" Value="{ThemeResource DataInspectorModifiedLineBackground}" />
        <Setter Property="AddedWordBrush" Value="{ThemeResource DataInspectorAddedWordBackground}" />
        <Setter Property="RemovedWordBrush" Value="{ThemeResource DataInspectorRemovedWordBackground}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="DiffViewer">
                <Border Name="RootBorder"
                        Background="Transparent"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        IsHitTestVisible="False" />
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderHover}" />
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderFocused}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{ThemeResource TextDisabled}" />
                <Setter Property="Opacity" Value="0.65" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="HexEditor">
        <Setter Property="Background" Value="{ThemeResource DataInspectorBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource DataInspectorForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource DataInspectorBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="FontFamily" Value="{ThemeResource MonoFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="MinHeight" Value="140" />
        <Setter Property="OffsetForeground" Value="{ThemeResource DataInspectorOffsetForeground}" />
        <Setter Property="HexForeground" Value="{ThemeResource DataInspectorHexForeground}" />
        <Setter Property="AsciiForeground" Value="{ThemeResource DataInspectorAsciiForeground}" />
        <Setter Property="ModifiedByteBrush" Value="{ThemeResource DataInspectorModifiedByteForeground}" />
        <Setter Property="SelectionBrush" Value="{ThemeResource DataInspectorSelectionBackground}" />
        <Setter Property="GutterBackground" Value="{ThemeResource DataInspectorGutterBackground}" />
        <Setter Property="ColumnSeparatorBrush" Value="{ThemeResource DataInspectorColumnSeparatorBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="HexEditor">
                <Border Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        ClipToBounds="True" />
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderHover}" />
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderFocused}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{ThemeResource TextDisabled}" />
                <Setter Property="Opacity" Value="0.65" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="JsonTreeViewer">
        <Setter Property="Background" Value="{ThemeResource DataInspectorBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource DataInspectorForeground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource DataInspectorBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="MinHeight" Value="180" />
        <Setter Property="ObjectBrush" Value="{ThemeResource DataInspectorJsonObjectBrush}" />
        <Setter Property="ArrayBrush" Value="{ThemeResource DataInspectorJsonArrayBrush}" />
        <Setter Property="StringBrush" Value="{ThemeResource DataInspectorJsonStringBrush}" />
        <Setter Property="NumberBrush" Value="{ThemeResource DataInspectorJsonNumberBrush}" />
        <Setter Property="BooleanBrush" Value="{ThemeResource DataInspectorJsonBooleanBrush}" />
        <Setter Property="NullBrush" Value="{ThemeResource DataInspectorJsonNullBrush}" />
        <Setter Property="KeyBrush" Value="{ThemeResource DataInspectorJsonKeyBrush}" />
        <Setter Property="BracketBrush" Value="{ThemeResource DataInspectorJsonBracketBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="JsonTreeViewer">
                <Border Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{ThemeResource DataInspectorToolbarBackground}"
                                BorderBrush="{ThemeResource DataInspectorBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="6,4,6,4">
                            <StackPanel Name="PART_ToolBar"
                                        Orientation="Horizontal">
                                <Button Name="PART_ExpandAllButton"
                                        Content="Expand All"
                                        Margin="0,0,6,0"
                                        Padding="8,4,8,4"
                                        MinWidth="0"
                                        MinHeight="0" />
                                <Button Name="PART_CollapseAllButton"
                                        Content="Collapse All"
                                        Margin="0,0,6,0"
                                        Padding="8,4,8,4"
                                        MinWidth="0"
                                        MinHeight="0" />
                                <Button Name="PART_CopyPathButton"
                                        Content="Copy Path"
                                        Padding="8,4,8,4"
                                        MinWidth="0"
                                        MinHeight="0" />
                            </StackPanel>
                        </Border>

                        <TextBox Name="PART_SearchBox"
                                 Grid.Row="1"
                                 Margin="6,6,6,6"
                                 PlaceholderText="Search JSON"
                                 BorderThickness="1" />

                        <TreeView Name="PART_TreeView"
                                  Grid.Row="2"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="2,0,2,0" />

                        <Border Name="PART_StatusBar"
                                Grid.Row="3"
                                Background="{ThemeResource DataInspectorToolbarBackground}"
                                BorderBrush="{ThemeResource DataInspectorBorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="8,4,8,4">
                            <TextBlock Name="PART_StatusText"
                                       Foreground="{ThemeResource DataInspectorForegroundSecondary}"
                                       FontSize="11" />
                        </Border>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{ThemeResource TextDisabled}" />
                <Setter Property="Opacity" Value="0.65" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Expander">
        <Setter Property="Background" Value="{ThemeResource SurfaceBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ControlBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HeaderBackground" Value="{ThemeResource ControlBackground}" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Expander">
                <Border Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        ClipToBounds="True">
                    <StackPanel>
                        <Border Name="PART_HeaderBorder"
                                Background="{TemplateBinding HeaderBackground}"
                                Padding="12,9,12,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Path Name="PART_Chevron"
                                      Grid.Column="0"
                                      Data="M 0,0 L 6,5 L 0,10"
                                      Stroke="{ThemeResource TextSecondary}"
                                      StrokeThickness="1.5"
                                      Width="8"
                                      Height="10"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0" />

                                <ContentPresenter Name="PART_HeaderContent"
                                                  Grid.Column="1"
                                                  Content="{TemplateBinding Header}"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Name="PART_ContentBorder"
                                Visibility="Collapsed"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_HeaderBorder" Property="Background" Value="{ThemeResource ControlBackgroundHover}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{ThemeResource TextDisabled}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderDisabled}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="CommandBar">
        <Setter Property="Background" Value="{ThemeResource CommandBarBackground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CommandBarBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimary}" />
        <Setter Property="MinHeight" Value="48" />
    </Style>

    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{ThemeResource ToolBarBackground}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ToolBarBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimary}" />
        <Setter Property="Padding" Value="6,4,6,4" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="ItemsPanel">
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="ToolBar">
                <Border Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                    <ItemsPresenter />
                </Border>
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{ThemeResource TextDisabled}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderDisabled}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ToolBarTray">
        <Setter Property="Background" Value="{ThemeResource ToolBarTrayBackground}" />
        <Setter Property="MinHeight" Value="48" />
    </Style>

    <Style TargetType="AppBarButton">
        <Setter Property="Background" Value="{ThemeResource AppBarButtonBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource AppBarButtonForeground}" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Template">
            <ControlTemplate TargetType="AppBarButton">
                <Border Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <ContentPresenter Content="{TemplateBinding Icon}"
                                          HorizontalAlignment="Center"
                                          Width="20"
                                          Height="20"
                                          Margin="0,4,0,0" />
                        <TextBlock Name="LabelText"
                                   Text="{TemplateBinding Label}"
                                   FontSize="10"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,2" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{ThemeResource AppBarButtonBackgroundHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{ThemeResource AppBarButtonBackgroundPressed}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{ThemeResource AppBarButtonForegroundDisabled}" />
            </Trigger>
            <Trigger Property="IsCompact" Value="True">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter Property="MinHeight" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="fluent:FWAppBarButton" BasedOn="{StaticResource {x:Type AppBarButton}}">
        <Setter Property="Density" Value="Comfortable" />
    </Style>

    <Style TargetType="AppBarToggleButton">
        <Setter Property="Background" Value="{ThemeResource AppBarButtonBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource AppBarButtonForeground}" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Template">
            <ControlTemplate TargetType="AppBarToggleButton">
                <Border Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <Grid>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <ContentPresenter Content="{TemplateBinding Icon}"
                                              HorizontalAlignment="Center"
                                              Width="20"
                                              Height="20"
                                              Margin="0,4,0,0" />
                            <TextBlock Name="LabelText"
                                       Text="{TemplateBinding Label}"
                                       FontSize="10"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,2" />
                        </StackPanel>
                        <Border Name="CheckedIndicator"
                                Height="3"
                                CornerRadius="1.5"
                                Background="{ThemeResource AccentBrush}"
                                VerticalAlignment="Bottom"
                                Margin="4,0,4,0"
                                Visibility="Collapsed" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{ThemeResource AppBarButtonBackgroundHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{ThemeResource AppBarButtonBackgroundPressed}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckedIndicator" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{ThemeResource AppBarButtonForegroundDisabled}" />
            </Trigger>
            <Trigger Property="IsCompact" Value="True">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter Property="MinHeight" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="fluent:FWAppBarToggleButton" BasedOn="{StaticResource {x:Type AppBarToggleButton}}">
        <Setter Property="Density" Value="Comfortable" />
    </Style>

    <Style TargetType="AppBarSeparator">
        <Setter Property="Foreground" Value="{ThemeResource AppBarSeparatorForeground}" />
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="6,8,6,8" />
    </Style>

    <Style TargetType="fluent:FWAppBarSeparator" BasedOn="{StaticResource {x:Type AppBarSeparator}}">
        <Setter Property="Density" Value="Comfortable" />
    </Style>

    <Style TargetType="NavigationView">
        <Setter Property="Background" Value="{ThemeResource WindowBackground}" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="PaneBackground" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="ContentBackground" Value="{ThemeResource WindowBackground}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="NavigationView">
                <Grid Name="PART_RootGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Name="PART_PaneContainer"
                            Grid.Column="0"
                            Background="{TemplateBinding PaneBackground}"
                            BorderBrush="{ThemeResource ControlBorder}"
                            BorderThickness="0,0,1,0"
                            Padding="0,8,0,0">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Name="PART_PaneHeaderHost"
                                    Grid.Row="0"
                                    Padding="16,8,16,10"
                                    Visibility="Collapsed" />

                            <ScrollViewer Name="PART_PaneScrollViewer"
                                          Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          ClipToBounds="True">
                                <StackPanel Name="PART_MenuItemsHost"
                                            Orientation="Vertical"
                                            Margin="0,2,0,2" />
                            </ScrollViewer>

                            <Border Name="PART_PaneFooterRegion"
                                    Grid.Row="2"
                                    Margin="0,2,0,6"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Vertical">
                                    <Border Background="{ThemeResource ControlBorder}"
                                            Height="1"
                                            Margin="18,0,18,6" />
                                    <StackPanel Name="PART_FooterItemsHost"
                                                Orientation="Vertical" />
                                    <Border Name="PART_PaneFooterHost"
                                            Padding="16,4,16,4"
                                            Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Name="PART_ContentContainer"
                            Grid.Column="1"
                            Background="{TemplateBinding ContentBackground}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style TargetType="NavigationViewItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="Margin" Value="6,1,6,1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Template">
            <ControlTemplate TargetType="NavigationViewItem">
                <StackPanel>
                    <Border Name="PART_ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Name="PART_SelectionIndicator"
                                    Grid.Column="0"
                                    Width="3"
                                    Height="18"
                                    CornerRadius="1.5"
                                    Background="{ThemeResource AccentBrush}"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed" />

                            <Border Name="PART_IndentSpacer"
                                    Grid.Column="1"
                                    Width="14" />

                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0" />

                            <Path Name="PART_Chevron"
                                  Grid.Column="3"
                                  Data="M 0,0 L 6,5 L 0,10"
                                  Stroke="{ThemeResource TextSecondary}"
                                  StrokeThickness="1.5"
                                  Width="8"
                                  Height="10"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,14,0"
                                  Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <StackPanel Name="PART_ChildrenPanel"
                                Orientation="Vertical"
                                Visibility="Collapsed" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_ItemBorder" Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="PART_ItemBorder" Property="Background" Value="{ThemeResource SelectionBackgroundWeak}" />
                <Setter TargetName="PART_SelectionIndicator" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PART_ItemBorder" Property="Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="NavigationViewItemHeader">
        <Setter Property="Foreground" Value="{ThemeResource TextSecondary}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="14,12,14,4" />
    </Style>

    <Style TargetType="NavigationViewItemSeparator">
        <Setter Property="Background" Value="{ThemeResource ControlBorder}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="18,6,18,6" />
    </Style>

</ResourceDictionary>
