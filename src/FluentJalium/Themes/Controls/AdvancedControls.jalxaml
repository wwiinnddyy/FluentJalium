        <Setter Property="MinHeight" Value="16" />
    </Style>

    <Style x:Key="CautionDotInfoBadgeStyle" TargetType="fluent:FWInfoBadge">
        <Setter Property="Severity" Value="Caution" />
        <Setter Property="Background" Value="{ThemeResource InfoBadgeCautionBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource InfoBadgeCautionForeground}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="6" />
        <Setter Property="MinHeight" Value="6" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="CautionValueInfoBadgeStyle" TargetType="fluent:FWInfoBadge">
        <Setter Property="Severity" Value="Caution" />
        <Setter Property="Background" Value="{ThemeResource InfoBadgeCautionBackground}" />
        <Setter Property="Foreground" Value="{ThemeResource InfoBadgeCautionForeground}" />
        <Setter Property="Padding" Value="4,0,4,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontFamily" Value="{ThemeResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="16" />
